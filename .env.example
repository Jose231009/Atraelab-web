# ─────────────────────────────────────────────────────────────
#  AtraeLab — Variables de Entorno
#  Copiar este archivo como .env.local y completar los valores
# ─────────────────────────────────────────────────────────────

# Resend — proveedor de emails para el formulario de contacto
# Obtener en: https://resend.com → API Keys
# IMPORTANTE: verificar el dominio atraelab.com en Resend antes de usar
RESEND_API_KEY=re_tu_api_key_aqui

# Email destino donde llegan los leads del formulario
# Puede ser cualquier email verificado en Resend
CONTACT_EMAIL=hola@atraelab.com
